@model BlindMatchPAS.Models.SupervisorMatch
@{
}

@if (Model != null && Model.IsRevealed)
{
    <div class="card border-success mb-4">
        <div class="card-header bg-success text-white">
            Revealed Partner Details
        </div>
        <div class="card-body">
            <h5 class="card-title">@Model.Supervisor?.FullName</h5>
            <p class="card-text">
                <strong>Email:</strong> @Model.Supervisor?.Email<br />
                <strong>Confirmed:</strong> @Model.ConfirmedAt?.ToString("g")
            </p>
        </div>
    </div>
}