@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">BlindMatch PAS</h1>
    <p class="lead">Project Approval System with Blind Matching</p>
    <hr />
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h4>How It Works</h4>
            <p class="text-muted">
                Students submit project proposals anonymously.<br />
                Supervisors browse proposals without seeing student identities.<br />
                When a supervisor confirms a match, both identities are revealed.
            </p>
        </div>
    </div>

    @if (!User.Identity?.IsAuthenticated == true)
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary me-2">Register</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Login</a>
        </div>
    }
</div>