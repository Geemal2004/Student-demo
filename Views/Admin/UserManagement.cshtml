@{
    ViewData["Title"] = "User Management";
}

<h2>User Management</h2>
<p>
    <a asp-action="CreateUser" class="btn btn-primary">Create New User</a>
</p>

<div class="row">
    <div class="col-md-6">
        <h4>Students</h4>
        <div id="students-list"></div>
    </div>
    <div class="col-md-6">
        <h4>Supervisors</h4>
        <div id="supervisors-list"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadUsers('Student', '#students-list');
            loadUsers('Supervisor', '#supervisors-list');
        });

        function loadUsers(role, target) {
            $.get('/Admin/GetUsersByRole?role=' + role, function(html) {
                $(target).html(html);
            });
        }
    </script>
}