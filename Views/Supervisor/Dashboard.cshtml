@using BlindMatchPAS.Models
@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<h2>Supervisor Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">@(ViewBag.Interests?.Count() ?? 0)</h5>
                <p class="card-text">Proposals of Interest</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">@(ViewBag.ConfirmedMatches?.Count() ?? 0)</h5>
                <p class="card-text">Confirmed Matches</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">@(ViewBag.Expertise?.Count() ?? 0)</h5>
                <p class="card-text">Expertise Areas</p>
            </div>
        </div>
    </div>
</div>

<h4>Proposals You Expressing Interest In</h4>
@if (ViewBag.Interests != null && ((IEnumerable<SupervisorMatch>)ViewBag.Interests).Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Research Area</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var match in (IEnumerable<SupervisorMatch>)ViewBag.Interests)
            {
                <tr>
                    <td>@match.Proposal?.Title</td>
                    <td>@match.Proposal?.ResearchArea?.Name</td>
                    <td>
                        <a asp-action="ConfirmMatch" asp-route-proposalId="@match.ProposalId" class="btn btn-sm btn-success">Confirm Match</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No interests expressed yet. <a asp-action="Browse">Browse proposals</a> to express interest.</p>
}

<h4 class="mt-4">Your Confirmed Matches</h4>
@if (ViewBag.ConfirmedMatches != null && ((IEnumerable<SupervisorMatch>)ViewBag.ConfirmedMatches).Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Project Title</th>
                <th>Confirmed At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var match in (IEnumerable<SupervisorMatch>)ViewBag.ConfirmedMatches)
            {
                <tr>
                    <td>@match.Proposal?.Student?.FullName</td>
                    <td>@match.Proposal?.Title</td>
                    <td>@match.ConfirmedAt?.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No confirmed matches yet.</p>
}