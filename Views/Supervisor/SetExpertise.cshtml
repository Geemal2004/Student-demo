@model IEnumerable<int>
@{
    ViewData["Title"] = "Set Expertise Areas";
}

<h2>Set Your Expertise Areas</h2>
<p>Select the research areas you can supervise.</p>

<form asp-action="SetExpertise" method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        @foreach (var area in (IEnumerable<BlindMatchPAS.Models.ResearchArea>)ViewBag.AllAreas)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="areaIds" value="@area.Id"
                       id="area_@area.Id"
                       @(ViewBag.CurrentExpertise?.Contains(area.Id) == true ? "checked" : "") />
                <label class="form-check-label" for="area_@area.Id">
                    <strong>@area.Name</strong> - @area.Description
                </label>
            </div>
        }
    </div>
    <button type="submit" class="btn btn-primary">Save Expertise</button>
</form>