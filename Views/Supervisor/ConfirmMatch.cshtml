@model BlindMatchPAS.Models.SupervisorMatch
@{
    ViewData["Title"] = "Confirm Match";
}

<h2>Confirm Match</h2>

<div class="alert alert-warning">
    <strong>Warning:</strong> Confirming this match will reveal your identity to the student!
</div>

<div class="card mb-4">
    <div class="card-header">Project Details</div>
    <div class="card-body">
        <h5 class="card-title">@Model.Proposal?.Title</h5>
        <p class="card-text">@Model.Proposal?.Abstract</p>
        <p class="card-text"><small class="text-muted">Research Area: @Model.Proposal?.ResearchArea?.Name</small></p>
    </div>
</div>

<form asp-action="ConfirmMatch" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="proposalId" value="@Model.ProposalId" />
    <div class="mb-3">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="confirmed" name="confirmed" value="true">
            <label class="form-check-label" for="confirmed">
                I confirm this match and agree to reveal my identity to the student
            </label>
        </div>
    </div>
    <button type="submit" class="btn btn-success">Confirm Match</button>
    <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
</form>