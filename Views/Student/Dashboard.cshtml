@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>
@{
    ViewData["Title"] = "My Proposals";
}

<h2>My Proposals</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New Proposal</a>
</p>
<div class="row">
    @foreach (var proposal in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <span class="badge rounded-pill @(proposal.Status switch {
                        BlindMatchPAS.Models.ProposalStatus.Pending => "bg-warning text-dark",
                        BlindMatchPAS.Models.ProposalStatus.UnderReview => "bg-info",
                        BlindMatchPAS.Models.ProposalStatus.Matched => "bg-success",
                        BlindMatchPAS.Models.ProposalStatus.Withdrawn => "bg-secondary",
                        _ => "bg-secondary"
                    })">
                        @proposal.Status
                    </span>
                    <span class="float-end">@proposal.ResearchArea?.Name</span>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@proposal.Title</h5>
                    <p class="card-text">@proposal.Abstract.Substring(0, Math.Min(150, proposal.Abstract.Length))...</p>
                    <p class="card-text"><small class="text-muted">Tech: @(proposal.TechnicalStack ?? "Not specified")</small></p>
                </div>
                <div class="card-footer">
                    <small class="text-muted">Created: @proposal.CreatedAt.ToShortDateString()</small>
                    @if (proposal.Status == BlindMatchPAS.Models.ProposalStatus.Pending)
                    {
                        <a asp-action="Edit" asp-route-id="@proposal.Id" class="btn btn-sm btn-secondary float-end">Edit</a>
                    }
                    @if (proposal.Status == BlindMatchPAS.Models.ProposalStatus.Matched)
                    {
                        <a asp-action="Details" asp-route-id="@proposal.Id" class="btn btn-sm btn-success float-end">View Match</a>
                    }
                </div>
            </div>
        </div>
    }
</div>