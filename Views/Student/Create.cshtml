@model BlindMatchPAS.Models.ProjectProposal
@{
    ViewData["Title"] = "Create Proposal";
}

<h2>Create New Proposal</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Title" class="form-label">Title (10-150 characters)</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Abstract" class="form-label">Abstract (100-1000 characters)</label>
        <textarea asp-for="Abstract" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Abstract" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="TechnicalStack" class="form-label">Technical Stack</label>
        <input asp-for="TechnicalStack" class="form-control" placeholder="e.g., .NET Core, React, PostgreSQL" />
        <span asp-validation-for="TechnicalStack" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ResearchAreaId" class="form-label">Research Area</label>
        <select asp-for="ResearchAreaId" class="form-select" asp-items="ViewBag.ResearchAreas">
            <option value="">-- Select Research Area --</option>
        </select>
        <span asp-validation-for="ResearchAreaId" class="text-danger"></span>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="IsAnonymous" class="form-check-input" checked />
        <label asp-for="IsAnonymous" class="form-check-label">Submit Anonymously</label>
    </div>
    <button type="submit" class="btn btn-primary">Submit Proposal</button>
    <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}