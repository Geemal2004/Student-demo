@model IEnumerable<BlindMatchPAS.DTOs.UserListDto>
@{
    ViewData["Title"] = "Users";
}

<h2>Users</h2>

<div class="mb-3">
    <form method="get" class="form-inline">
        <label class="me-2">Filter by Role:</label>
        <select name="roleFilter" class="form-select me-2" style="width: auto;">
            <option value="">All</option>
            <option value="Student" selected="@(Context.Request.Query["roleFilter"] == "Student")">Students</option>
            <option value="Supervisor" selected="@(Context.Request.Query["roleFilter"] == "Supervisor")">Supervisors</option>
        </select>
        <button type="submit" class="btn btn-secondary">Filter</button>
    </form>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>
                    <span class="badge @(user.Role == "Student" ? "bg-success" : user.Role == "Supervisor" ? "bg-primary" : "bg-secondary")">@user.Role</span>
                </td>
                <td>
                    <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">@(user.IsActive ? "Active" : "Deactivated")</span>
                </td>
            </tr>
        }
    </tbody>
</table>